{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/openapi.json",
      "dest": "backend/main.py"
    },
    {
      "src": "/docs",
      "dest": "backend/main.py"
    },
    {
      "src": "/travel/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/recommend/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/sentiment/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/reviews",
      "dest": "backend/main.py"
    },
    {
      "src": "/debug",
      "dest": "backend/main.py"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
